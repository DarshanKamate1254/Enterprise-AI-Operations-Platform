# ==============================================================================
# Enterprise AI Operations Platform - Environment Configuration Template
# ==============================================================================

# --- General Application Config ---
APP_NAME="Enterprise AI Operations Platform"
APP_ENV=development  # development, staging, production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# --- Security & JWT Config ---
JWT_SECRET_KEY=generate-a-strong-32-byte-hex-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database Config (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=enterprise_ai_ops

# --- Caching Config (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_secure_pass

# --- Vector Database Config (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secure_api_key_here
QDRANT_USE_HTTPS=false

# --- LLM API Providers ---
OPENAI_API_KEY=sk-proj-placeholderopenaiapikeyhere
ANTHROPIC_API_KEY=sk-ant-placeholderanthropicapikeyhere

# --- Default AI Model Settings ---
DEFAULT_LLM_PROVIDER=openai  # openai, anthropic
DEFAULT_CHAT_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# --- LangSmith Observability & Tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_placeholderkeyhere
LANGCHAIN_PROJECT=enterprise-ai-ops-platform

# --- Telemetry & Metrics ---
LOG_LEVEL=INFO
PROMETHEUS_METRICS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Model Context Protocol (MCP) Configuration ---
MCP_SERVER_URL=http://localhost:8080/mcp
MCP_AUTH_TOKEN=mcp_secure_handshake_token_here
